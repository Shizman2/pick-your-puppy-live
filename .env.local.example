# Copy this file to .env.local and fill in your real values.
# .env.local should never be committed or shared - it's for your machine only.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (or service_role key) - server-side only, never exposed to the browser.
# Do not add a NEXT_PUBLIC_ prefix to this one.
SUPABASE_SECRET_KEY=
